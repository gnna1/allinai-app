# ============================================
# AllInAI Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# JWT Secret (change this! use: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-string

# Database (PostgreSQL for production, SQLite for local dev)
# Option A: PostgreSQL (for Vercel/Supabase/Neon)
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Option B: SQLite (for local development only)
# DATABASE_URL=file:./prisma/allinai.db

# ---- Domestic Models ----
# Get these free from each platform's console

# DeepSeek: console.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-key

# 通义千问: dashscope.aliyun.com
TONGYI_API_KEY=sk-your-tongyi-key

# 智谱 GLM: open.bigmodel.cn
ZHIPU_API_KEY=your-zhipu-key

# 豆包 (火山引擎): console.volcengine.com/ark
DOUBAO_API_KEY=your-doubao-key

# Kimi (月之暗面): platform.moonshot.cn
KIMI_API_KEY=sk-your-kimi-key

# ---- Payment: 易支付 (yi-zhifu.com) ----
# 注册后获得这些值
# YIPAY_PID=你的商户ID
# YIPAY_KEY=你的商户密钥
# YIPAY_NOTIFY_URL=https://你的域名/api/payment/callback
# Option A: OpenAI direct (needs overseas payment)
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_API_BASE=https://api.openai.com/v1

# Option B: Through a Chinese proxy platform like 非线智能API
# Settings for using nonelinear.com or similar
# OPENAI_API_KEY=sk-your-nonelinear-key
# OPENAI_API_BASE=https://api.nonelinear.com/v1
# CLAUDE_API_KEY=sk-your-nonelinear-key
# CLAUDE_API_BASE=https://api.nonelinear.com/v1
